# Copy this file to .streamlit/secrets.toml (gitignored) for local dev
# OR paste these values into Streamlit Cloud's "Secrets" section in the dashboard
#
# When deployed, the app will read from Streamlit's secret store FIRST,
# then fall back to keys.json, then to .env.

# Your RapidAPI key for cricket-live-line-advance
RAPIDAPI_KEY = "paste_your_key_here"

# Optional: pre-seed multiple keys (the app will use the first one as default)
# RAPIDAPI_KEY_2 = "second_account_key"
# RAPIDAPI_KEY_3 = "third_account_key"
